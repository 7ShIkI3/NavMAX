# ═══════════════════════════════════════════════════════════════════
# NavMAX — Configuration variables d'environnement
# Copier vers .env et adapter les valeurs
# ═══════════════════════════════════════════════════════════════════
# cp .env.example .env && $EDITOR .env
# ═══════════════════════════════════════════════════════════════════

# ─── Général ──────────────────────────────────────────────────────
NAVMAX_DEBUG=false
NAVMAX_LOG_LEVEL=INFO
NAVMAX_LOG_FORMAT=json                        # json | console

# ─── API ──────────────────────────────────────────────────────────
NAVMAX_API_HOST=0.0.0.0
NAVMAX_API_PORT=8000
NAVMAX_API_WORKERS=2

# ─── Base de données PostgreSQL ───────────────────────────────────
# Chaîne de connexion PostgreSQL asynchrone (via asyncpg)
NAVMAX_DATABASE_URL=postgresql+asyncpg://navmax:ChangerMoi!@postgres:5432/navmax

# Identifiants PostgreSQL (utilisés par le service postgres)
POSTGRES_USER=navmax
POSTGRES_PASSWORD=ChangerMoi!
POSTGRES_DB=navmax

# ─── Redis ────────────────────────────────────────────────────────
NAVMAX_REDIS_URL=redis://:navmax_redis_secret@redis:6379/0

# Mot de passe Redis (doit correspondre à celui du service redis)
REDIS_PASSWORD=navmax_redis_secret

# ─── JWT ──────────────────────────────────────────────────────────
# Générer une clé secrète forte : openssl rand -hex 64
NAVMAX_JWT_SECRET=ChangezMoiAvecUneCleSecreteLongue64caracteresMin!
NAVMAX_JWT_ALGORITHM=HS256
NAVMAX_JWT_EXPIRE_MINUTES=60

# ─── Scanner ──────────────────────────────────────────────────────
NAVMAX_SCANNER_DEFAULT_TIMEOUT=2.0
NAVMAX_SCANNER_DEFAULT_PORTS=22,23,25,53,80,110,111,135,139,143,443,445,993,995,1723,3306,3389,5900,8080,8443,27017
NAVMAX_SCANNER_MAX_CONCURRENCY=100
NAVMAX_SCANNER_UDP_ENABLED=false

# ─── Proxy ────────────────────────────────────────────────────────
NAVMAX_PROXY_PORT=8080
NAVMAX_PROXY_CA_DIR=/data/navmax/certs

# ─── Exploit ──────────────────────────────────────────────────────
NAVMAX_EXPLOIT_MODULES_DIR=/data/navmax/exploits
NAVMAX_EXPLOIT_PAYLOAD_DIR=/data/navmax/payloads

# ─── Données ──────────────────────────────────────────────────────
# Répertoire de données persistant (monté dans le conteneur)
NAVMAX_DATA_DIR=/data/navmax

# ─── Nginx (reverse proxy) ────────────────────────────────────────
NGINX_PORT=80
NGINX_SERVER_NAME=localhost
# Limite de requêtes par IP (req/s)
NGINX_RATE_LIMIT=10
