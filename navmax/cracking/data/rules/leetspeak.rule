# Avec suffixes numériques
sa@ $1
sa@ $2
sa@ $3
sa@ $1$2$3
se3 $1
se3 $2
se3 $1$2$3
c sa@ $1
c sa@ $2
c sa@ $1$2$3
c se3 $1
c se3 $2
c se3 $1$2$3
u sa@ $1
u sa@ $2
u sa@ $1$2$3
u se3 $1
u se3 $2
u se3 $1$2$3

# Avec préfixes
^! sa@
^@ sa@
^! se3
^@ se3
c ^! sa@
c ^! se3
u ^! sa@
u ^! se3

# Combinaisons l33t avancées
sa4 se3 si1 ss5 so0
sa4 se3 si1 so0
sa4 se3 si1 ss5
c sa4 se3 si1 ss5 so0
u sa4 se3 si1 ss5 so0
c sa4 $! se3 $!
u sa4 $! se3 $!
sa@ sa@@
se3 se33
si1 si11
so0 so00
ss5 ss55
sa@ $! se3 $! si1 $!
sa@ $! se3 $! si1 $! ss5 $!
c sa@ $! se3 $! si1 $! ss5 $!
u sa@ $! se3 $! si1 $! ss5 $!

